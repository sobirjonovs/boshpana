# Boshpana.ai — parser service
# Backend ingest API base URL and bearer token.
BACKEND_URL=http://localhost:8000/api/v1
INGEST_API_TOKEN=local-ingest-token

# Telegram (Telethon) credentials — only needed for the telegram scraper.
# Leave empty to disable real Telegram scraping (TelegramScraper returns []).
TG_API_ID=
TG_API_HASH=
# StringSession produced once via Telethon; empty = no session.
TG_SESSION=

# Only ingest listings posted within the last N hours (default 24).
PARSE_SINCE_HOURS=24
