# Boshpana.ai — userbot (AI negotiator transport)

# Backend REST API base URL and the userbot service token (Bearer).
BACKEND_URL=http://localhost:8000/api/v1
USERBOT_API_TOKEN=local-userbot-token

# Telegram API credentials (https://my.telegram.org) — required for REAL mode.
# Leave empty to run --simulation without any Telegram account.
TG_API_ID=
TG_API_HASH=
TG_STRING_SESSION=

# SAFETY: the userbot ONLY messages these accounts (your own test accounts that
# role-play apartment owners). Real owners are NEVER contacted. Comma-separated;
# each may be a @username, a +phone number, or a numeric id, e.g.
# TARGET_USER_IDS=@my_test_account,+998901234567
TARGET_USER_IDS=

# Seconds to wait for a target reply before concluding as no_response.
RESPONSE_TIMEOUT=180

# How often (seconds) to poll the backend for new negotiation tasks.
POLL_INTERVAL=5
