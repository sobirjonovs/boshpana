# Telegram bot token from @BotFather
BOT_TOKEN=

# Boshpana.ai backend API (v1 base URL)
BACKEND_URL=http://localhost:8000/api/v1

# Service token for bot-facing endpoints (must match backend config boshpana.tokens.bot)
BOT_API_TOKEN=local-bot-token

# Default UI language: uz | ru | en
DEFAULT_LANG=uz
